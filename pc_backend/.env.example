# ESP32 Voice Assistant Backend Configuration
# Copy this to .env and fill in your values

# Server settings
WS_HOST=0.0.0.0
WS_PORT=8765

# STT settings
# Options: tiny.en, base.en, small.en, medium.en, large-v3
STT_MODEL_SIZE=base.en
# "cpu" or "cuda" (requires CTranslate2 with CUDA)
STT_DEVICE=cpu
# "int8" for CPU, "float16" for CUDA
STT_COMPUTE_TYPE=int8

# Ollama LLM settings
# Install Ollama: https://ollama.com  then run: ollama pull llama3.2
OLLAMA_URL=http://localhost:11434
OLLAMA_MODEL=llama3.2

# Conversation memory (number of turns to keep)
MAX_CONVERSATION_TURNS=10

# System prompt for the assistant personality
# SYSTEM_PROMPT=You are a helpful voice assistant...
